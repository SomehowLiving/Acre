{
  "name": "AcreVerification",
  "methods": [
    {
      "name": "update_verifier",
      "args": [
        {
          "type": "address",
          "name": "new_verifier"
        }
      ],
      "returns": {
        "type": "void"
      },
      "desc": "Change the backend verifier address.\nOnly admin can call this."
    },
    {
      "name": "verify_income",
      "args": [
        {
          "type": "address",
          "name": "user_wallet",
          "desc": "The gig worker's Algorand address"
        },
        {
          "type": "uint8",
          "name": "tier",
          "desc": "Income tier (1=<25k limit, 2=25-50k, 3=>50k)"
        },
        {
          "type": "uint64",
          "name": "credit_limit",
          "desc": "Maximum loan amount in rupees"
        },
        {
          "type": "uint64",
          "name": "timestamp",
          "desc": "Unix timestamp of verification"
        },
        {
          "type": "byte[32]",
          "name": "proof_hash",
          "desc": "SHA256 hash of Reclaim proof (prevents replay)"
        },
        {
          "type": "uint64",
          "name": "rider_count",
          "desc": "Total Uber rides (activity signal)"
        },
        {
          "type": "uint64",
          "name": "rider_rating",
          "desc": "Rating * 100 (485 = 4.85 stars)"
        },
        {
          "type": "string",
          "name": "platform",
          "desc": "\"uber\", \"lyft\", etc."
        },
        {
          "type": "uint16",
          "name": "score",
          "desc": "Blue Score, 0-1000"
        },
        {
          "type": "uint8",
          "name": "income_bucket",
          "desc": "1=<20k, 2=20-35k, 3=35-50k, 4=>50k"
        },
        {
          "type": "uint8",
          "name": "tenure_bucket",
          "desc": "1=<6mo, 2=6-12mo, 3=12-24mo, 4=>24mo"
        },
        {
          "type": "uint8",
          "name": "completion_bucket",
          "desc": "1=<85%, 2=85-92%, 3=92-97%, 4=>97%"
        },
        {
          "type": "uint8",
          "name": "rating_bucket",
          "desc": "1=<4.0, 2=4.0-4.5, 3=4.5-4.8, 4=>4.8"
        },
        {
          "type": "string",
          "name": "source",
          "desc": "\"reclaim\" or \"fallback\""
        },
        {
          "type": "uint8",
          "name": "plausibility_flags",
          "desc": "bitmask, 0 means clean"
        },
        {
          "type": "uint64",
          "name": "monthly_earnings",
          "desc": "monthly earnings in rupees"
        },
        {
          "type": "uint64",
          "name": "tenure_months",
          "desc": "actual platform tenure in months"
        },
        {
          "type": "uint64",
          "name": "completion_rate",
          "desc": "completion rate * 100 (9600 = 96%)"
        }
      ],
      "returns": {
        "type": "void"
      },
      "desc": "Store income verification data and the full Blue Score audit record."
    },
    {
      "name": "get_eligibility",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint64"
      },
      "desc": "Returns credit limit for a user.\nReturns 0 if not verified."
    },
    {
      "name": "is_verified",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint8"
      },
      "desc": "Check if user has verified income.\nReturns: 1 = verified, 0 = not verified"
    },
    {
      "name": "get_tier",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint8"
      },
      "desc": "Get income tier (1, 2, or 3).\nReturns 0 if not verified."
    },
    {
      "name": "get_credit_limit",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint64"
      },
      "desc": "Get credit limit in rupees.\nAlias for get_eligibility."
    },
    {
      "name": "get_full_profile",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "(uint8,uint8,uint64,uint64,uint64,uint64,string,uint16,uint64,string,uint8,uint64,uint64,uint64)"
      },
      "desc": "Get all verification details at once.\nReturns tuple: (verified, tier, limit, timestamp, rides, rating, platform,  score, buckets, source, plausibility_flags, monthly_earnings,  tenure_months, completion_rate)"
    },
    {
      "name": "get_score",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint16"
      },
      "desc": "Get Blue Score (0-1000). Returns 0 if not verified."
    },
    {
      "name": "get_score_breakdown",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "(uint8,uint8,uint8,uint8)"
      },
      "desc": "Get score buckets: income, tenure, completion, rating."
    },
    {
      "name": "get_source",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "string"
      },
      "desc": "Get verification source: reclaim, fallback, onchain_derived, etc."
    },
    {
      "name": "has_plausibility_issues",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "uint8"
      },
      "desc": "Returns 1 if plausibility flags > 0."
    },
    {
      "name": "get_proof_hash",
      "args": [
        {
          "type": "address",
          "name": "user"
        }
      ],
      "returns": {
        "type": "byte[32]"
      },
      "desc": "Get the hash of the Reclaim proof used for verification.\nReturns empty bytes if not verified."
    },
    {
      "name": "get_verifier",
      "args": [],
      "returns": {
        "type": "address"
      },
      "desc": "Returns the current verifier address."
    },
    {
      "name": "get_admin",
      "args": [],
      "returns": {
        "type": "address"
      },
      "desc": "Returns the admin address."
    },
    {
      "name": "get_proof_count",
      "args": [],
      "returns": {
        "type": "uint64"
      },
      "desc": "Returns total number of proofs stored."
    }
  ],
  "networks": {}
}