# Backend server config (server.js)
PORT=3001
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
APP_ID=
VERIFIER_MNEMONIC=

# DigiLocker identity
ACRE_DIGILOCKER_BASE_URL=https://dg-sandbox.setu.co
ACRE_DIGILOCKER_REDIRECT_URL=http://localhost:8080/digi
http://localhost:5173/identity/callback
ACRE_DIGILOCKER_CLIENT_ID=
ACRE_DIGILOCKER_CLIENT_SECRET=
ACRE_DIGILOCKER_PRODUCT_INSTANCE_ID=
ACRE_DIGILOCKER_TIMEOUT_SECONDS=15
ACRE_DIGILOCKER_MOCK_AUTO_VERIFY=true

# AlgoPlonk verification
ACRE_ALGOPLONK_VERIFY_APP_ID=
ACRE_ALGOPLONK_VERIFY_METHOD_SIGNATURE=verify(byte[32][],byte[32][])bool
ACRE_ALGOPLONK_REQUIRE_ONCHAIN_VERIFY=false
ACRE_ALGOPLONK_SIMULATE_ONLY=false

# AI Advisor (ACRE chat assistant)
# OPENAI_API_KEY: used first. Model: gpt-4o-mini.
OPENAI_API_KEY=
# GROQ_API_KEY: fallback if OpenAI key is absent or fails. Model: llama-3.1-70b-versatile.
GROQ_API_KEY=

# Consent token + attestation
# ACRE_DEMO_SECRET: HMAC key for consent token signing. Defaults to a derived local key if unset.
# Set to a strong random value in production.
ACRE_DEMO_SECRET=
# ACRE_REGISTRAR_MNEMONIC: Ed25519 key used to sign contract attestations and note anchor txs.
# Defaults to VERIFIER_MNEMONIC if unset.
ACRE_REGISTRAR_MNEMONIC=
